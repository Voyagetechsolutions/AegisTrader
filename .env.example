# ============================================================
# AEGIS TRADER – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production

# REQUIRED: Strong secrets (min 32 chars for JWT, min 16 chars for MT5)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_JWT_SECRET=CHANGE_ME_MIN_32_CHARS_REQUIRED_FOR_JWT_SECURITY
MT5_NODE_SECRET=CHANGE_ME_MIN_16_CHARS_REQUIRED

# --- Database (PostgreSQL / Supabase) ---
# For local dev, SQLite is used by default (see config.py)
# For production, use PostgreSQL:
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/aegis_trader

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- MT5 Execution Node ---
# URL of the FastAPI server running on the Windows VPS alongside MT5
MT5_NODE_URL=http://localhost:8001

# --- MT5 Account (used by mt5_node) ---
MT5_ACCOUNT=123456
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Server

# --- News Filter ---
# Manual override: set to true to bypass news filter during testing
NEWS_FILTER_BYPASS=false

# --- Risk Defaults ---
MAX_DAILY_TRADES=2
MAX_DAILY_LOSSES=2
MAX_DAILY_DRAWDOWN_PCT=2.0
MAX_SPREAD_POINTS=5
MAX_SLIPPAGE_POINTS=10

# --- Scheduler ---
# Timezone for session windows (SAST = Africa/Johannesburg)
TIMEZONE=Africa/Johannesburg

# --- Render / Cloud ---
PORT=8000
